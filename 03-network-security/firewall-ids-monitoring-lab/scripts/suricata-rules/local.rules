alert http any any -> $HOME_NET any (msg:"LOCAL Possible SQL Injection Attempt"; flow:to_server,established; http.uri; content:"union"; nocase; content:"select"; nocase; sid:1000001; rev:1;)
alert http any any -> $HOME_NET any (msg:"LOCAL Possible XSS Script Tag"; flow:to_server,established; http.uri; content:"<script"; nocase; sid:1000002; rev:1;)
alert tcp any any -> $HOME_NET any (msg:"LOCAL Possible TCP SYN Port Scan"; flags:S; flow:stateless; threshold:type both, track by_src, count 15, seconds 10; sid:1000003; rev:1;)
